# =============================================================================
# Mundo Chichín — WordPress configuration
# Copia este archivo a `.env` y rellena los valores. NUNCA subas `.env` a Git.
# =============================================================================

# Nombre del proyecto (Docker Compose lo usa para nombrar contenedores/volúmenes)
COMPOSE_PROJECT_NAME=mundochichin

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# URL pública (sin barra final).
#   Local: http://localhost:8090
#   Prod:  https://mundochichin.com
WP_SITE_URL=http://localhost:8090

# Dominios para Caddy (sólo prod). Separados por coma.
WP_DOMAIN=mundochichin.com,www.mundochichin.com

# Email para Let's Encrypt (sólo prod)
CADDY_EMAIL=admin@mundochichin.com

# Puertos en local (no aplican en prod, Caddy escucha 80/443)
WP_LOCAL_PORT=8090
PMA_LOCAL_PORT=8091

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_NAME=mundochichin
DB_USER=wpuser
DB_PASSWORD=cambia_esto_en_prod
DB_ROOT_PASSWORD=cambia_esto_root_en_prod

# Prefijo de tablas del dump original (NO cambiar)
WP_TABLE_PREFIX=wppb_

# -----------------------------------------------------------------------------
# Salts → en config/wp-salts.php
# Copia config/wp-salts.php.example a config/wp-salts.php y pega los salts
# generados en: https://api.wordpress.org/secret-key/1.1/salt/
# -----------------------------------------------------------------------------
